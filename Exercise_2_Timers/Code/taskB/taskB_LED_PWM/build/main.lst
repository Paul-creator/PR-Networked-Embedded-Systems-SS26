 167:Src/main.c    ****   uint8_t bright_step = 5U;   // start at 50% brightness
 168:Src/main.c    **** 
 169:Src/main.c    ****   set_led_brightness(bright_step);
 170:Src/main.c    ****   /* USER CODE END 2 */
 171:Src/main.c    **** 
 172:Src/main.c    ****   /* Infinite loop */
 173:Src/main.c    ****   /* USER CODE BEGIN WHILE */
 174:Src/main.c    ****   while (1)
 175:Src/main.c    ****   {
 176:Src/main.c    ****     /* BTN1 (PJ12): increase brightness */
 177:Src/main.c    ****     if (HAL_GPIO_ReadPin(GPIOJ, BTN1_Pin) == GPIO_PIN_RESET)
 178:Src/main.c    ****     {
 179:Src/main.c    ****       if (bright_step < 10U)
 180:Src/main.c    ****       {
 181:Src/main.c    ****         bright_step++;
 182:Src/main.c    ****         set_led_brightness(bright_step);
 183:Src/main.c    ****       }
 184:Src/main.c    ****       HAL_Delay(150); // debounce
 185:Src/main.c    ****     }
 186:Src/main.c    **** 
 187:Src/main.c    ****     /* BTN2 (PJ13): decrease brightness */
 188:Src/main.c    ****     if (HAL_GPIO_ReadPin(GPIOJ, BTN2_Pin) == GPIO_PIN_RESET)
 189:Src/main.c    ****     {
 190:Src/main.c    ****       if (bright_step > 0U)
 191:Src/main.c    ****       {
 192:Src/main.c    ****         bright_step--;
 193:Src/main.c    ****         set_led_brightness(bright_step);
 194:Src/main.c    ****       }
 195:Src/main.c    ****       HAL_Delay(150);
 196:Src/main.c    ****     }
 197:Src/main.c    ****   }
 198:Src/main.c    ****   /* USER CODE END 3 */
